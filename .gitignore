# Dependencies
node_modules/

# Build output (regenerated by tsc/vite)
dist/
build/

# Prisma generated clients (regenerated on build via `prisma generate`)
backend/services/*/prisma/generated/
backend/shared/*/prisma/generated/

# Environment — NEVER commit real secrets
.env
.env.local
.env.*.local

# Docker data volumes (local dev artefacts, not source)
uploads/
data/
postgres_data/

# Logs
logs/
*.log
npm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
*.swp
*.swo

# SSH keys / private keys
*.pem

# TypeScript incremental build info
*.tsbuildinfo

# Test coverage
coverage/
