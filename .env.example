# ── ProcureFlow — Local Development / Docker Compose Environment ─────────────
# Copy this file to .env and fill in your values. Everything needed to run
# this app lives here — no AWS account, AWS CLI, or cloud credentials needed.

# Node
NODE_ENV=development
PORT=5000

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Single Postgres instance, one schema per service (identity/finance/
# procurement/document) via Prisma's multiSchema support.
POSTGRES_USER=procureflow
POSTGRES_PASSWORD=procureflow
POSTGRES_DB=procureflow
DATABASE_URL=postgresql://procureflow:procureflow@localhost:5432/procureflow

# ── File storage ───────────────────────────────────────────────────────────────
# Local filesystem path (mounted as a Docker volume in production) where
# uploaded documents and generated PDFs are stored.
UPLOADS_DIR=./uploads

# ── Field-level encryption ─────────────────────────────────────────────────────
# Used for PAN/Aadhar/bank-account fields on Employee records. Must be at
# least 32 characters in production.
ENCRYPTION_KEY=dev_encryption_key_change_in_production_32b

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_secure_random_string_at_least_32_chars
JWT_REFRESH_SECRET=change_this_to_another_secure_random_string_at_least_32_chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Admin bootstrap ────────────────────────────────────────────────────────────
# There is no public registration route. Exactly one admin account is seeded
# on identity-service startup from these two values if no admin exists yet.
ADMIN_EMAIL=admin@procureflow.com
ADMIN_PASSWORD=changeme123

# ── SendGrid (email: password reset, invoice/contract alerts, new accounts) ──
# Leave SENDGRID_API_KEY blank to log emails to the console instead of sending.
SENDGRID_API_KEY=
SENDGRID_FROM=noreply@procureflow.com

# ── Frontend URL (used to build links inside emails) ─────────────────────────
FRONTEND_URL=http://localhost
